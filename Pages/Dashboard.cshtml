@page
@using EncuentraTuHogar.Frontend.Helpers
@model EncuentraTuHogar.Pages.DashboardModel
@{
    ViewData["Title"] = "Mi Perfil";
    string initials = string.IsNullOrEmpty(Model.UserFullName) ? "U" :
        string.Join("", Model.UserFullName.Split(' ').Select(w => w.Length > 0 ? w[0].ToString() : "").Take(2)).ToUpper();
}

<div style="max-width: var(--container); margin: 3rem auto; padding: 0 var(--container-pad);">

    <!-- Page Header -->
    <div class="reveal" style="margin-bottom: 2rem;">
        <span class="section-eyebrow">Panel de usuario</span>
        <h1 class="section-title" style="margin-bottom:0;">Mi Perfil</h1>
    </div>

    <div class="dashboard-grid">

        <!-- ── Profile Card (Sidebar) ── -->
        <aside class="profile-card reveal">
            <div class="profile-avatar">
                @initials
                <div class="profile-verified" title="Usuario verificado">✓</div>
            </div>
            <div class="profile-name">@Model.UserFullName</div>
            <div class="profile-since">Miembro desde 2026</div>

            <div class="profile-stats">
                <div class="profile-stat">
                    <span class="profile-stat-num">@Model.MisVisitasProgramadas.Count()</span>
                    <span class="profile-stat-label">Visitas</span>
                </div>
                <div class="profile-stat">
                    <span class="profile-stat-num">@Model.MisPropiedades.Count()</span>
                    <span class="profile-stat-label">Propiedades</span>
                </div>
            </div>

            <div style="border-top: 1px solid var(--border); padding-top: 1.25rem; display: flex; flex-direction: column; gap: 0.5rem;">
                <span class="badge badge-green" style="justify-content:center;">
                    ✓ Identidad verificada
                </span>
                <a href="/Comunidad" class="btn btn-ghost btn-sm" id="btn-ir-comunidad">
                    💬 Ir a la Comunidad
                </a>
                <a href="/CrearAnuncio" class="btn btn-outline btn-sm" id="btn-nuevo-anuncio">
                    + Publicar vivienda
                </a>
            </div>
        </aside>

        <!-- ── Main Content ── -->
        <div class="dashboard-content">

            <!-- Visits Card -->
            <div class="dash-card reveal">
                <div class="dash-card-header">
                    <h3>
                        <span style="margin-right:0.5rem;">📅</span>
                        Mis Visitas Programadas
                    </h3>
                    @if (Model.MisVisitasProgramadas.Any())
                    {
                        <span class="badge badge-blue">@Model.MisVisitasProgramadas.Count() visita@(Model.MisVisitasProgramadas.Count() != 1 ? "s" : "")</span>
                    }
                </div>
                <div class="dash-card-body">
                    @if (Model.MisVisitasProgramadas.Any())
                    {
                        @foreach (var visita in Model.MisVisitasProgramadas)
                        {
                            string statusClass = visita.Status switch {
                                EncuentraTuHogar.Domain.ValueObjects.VisitStatus.Confirmed => "status-confirmed",
                                EncuentraTuHogar.Domain.ValueObjects.VisitStatus.Completed => "status-confirmed",
                                EncuentraTuHogar.Domain.ValueObjects.VisitStatus.Cancelled => "status-cancelled",
                                _ => "status-pending"
                            };
                            string statusLabel = visita.Status switch {
                                EncuentraTuHogar.Domain.ValueObjects.VisitStatus.Confirmed => "Confirmada",
                                EncuentraTuHogar.Domain.ValueObjects.VisitStatus.Completed => "Completada",
                                EncuentraTuHogar.Domain.ValueObjects.VisitStatus.Cancelled => "Cancelada",
                                _ => "Pendiente"
                            };
                            <div class="visit-item">
                                <div class="visit-icon">🏠</div>
                                <div class="visit-info">
                                    <div class="visit-prop">Propiedad #@visita.PropertyId</div>
                                    <div class="visit-date">
                                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" style="margin-right:3px;vertical-align:middle;">
                                            <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                                        </svg>
                                        @visita.ScheduledDate.ToString("dd MMM yyyy, HH:mm")
                                    </div>
                                </div>
                                <span class="status-badge @statusClass">@statusLabel</span>
                            </div>
                        }
                    }
                    else
                    {
                        <div style="text-align:center;padding:3rem 1rem;color:var(--text-muted);">
                            <div style="font-size:2.5rem;margin-bottom:1rem;opacity:0.4;">📅</div>
                            <p style="margin:0;font-size:0.9375rem;">No tienes visitas programadas aún.</p>
                            <a href="/#propiedades" class="btn btn-outline btn-sm" style="margin-top:1rem;" id="btn-explorar-dash">
                                Explorar propiedades
                            </a>
                        </div>
                    }
                </div>
            </div>

            <!-- Properties Card -->
            <div class="dash-card reveal">
                <div class="dash-card-header">
                    <h3>
                        <span style="margin-right:0.5rem;">🏡</span>
                        Mis Propiedades Publicadas
                    </h3>
                    @if (Model.MisPropiedades.Any())
                    {
                        <span class="badge badge-green">@Model.MisPropiedades.Count() publicada@(Model.MisPropiedades.Count() != 1 ? "s" : "")</span>
                    }
                </div>
                <div class="dash-card-body">
                    @if (Model.MisPropiedades.Any())
                    {
                        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:1rem;">
                            @foreach (var prop in Model.MisPropiedades)
                            {
                                <div style="border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;background:var(--bg-subtle);">
                                    <div style="height:90px;background:linear-gradient(135deg,var(--bg-muted),var(--primary-light));display:flex;align-items:center;justify-content:center;font-size:2rem;opacity:0.5;">🏠</div>
                                    <div style="padding:0.875rem;">
                                        <div style="font-weight:700;font-size:0.875rem;color:var(--text);margin-bottom:0.25rem;">@prop.City, @prop.Neighborhood</div>
                                        <div style="display:flex;flex-direction:column;gap:0.25rem;margin-bottom:0.625rem;">
                                            <span class="badge badge-gray">@TranslationHelper.TranslatePropertyType(prop.Type)</span>
                                            <span class="badge badge-green">@TranslationHelper.TranslateTransactionType(prop.Transaction)</span>
                                        </div>
                                        <div style="font-size:1rem;font-weight:800;color:var(--primary);">$@prop.Price.ToString("N0")</div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div style="text-align:center;padding:3rem 1rem;color:var(--text-muted);">
                            <div style="font-size:2.5rem;margin-bottom:1rem;opacity:0.4;">🏡</div>
                            <p style="font-size:0.9375rem;margin-bottom:1.25rem;color:var(--text-secondary);">Aún no tienes propiedades publicadas.<br>¡Conecta con cientos de inquilinos verificados!</p>
                            <a href="/CrearAnuncio" class="btn btn-primary" id="btn-publicar-dash">
                                Publicar mi primera vivienda
                            </a>
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>
</div>
