@page
@using EncuentraTuHogar.Frontend.Helpers
@model IndexModel
@{
    ViewData["Title"] = "Inicio";
}

<!-- Hero Section -->
<section class="hero-section">
    <div class="hero-content">
        <h1>Encuentra tu vivienda <br><span>rápida y fácil</span></h1>
        <p>Soluciones a tu alcance</p>
        
        <form method="get" action="/#propiedades" class="search-box">
            <div class="search-input-group">
                <select id="city" name="City" asp-for="City">
                    <option value="">Ciudad</option>
                    <option value="medellin">Medellín</option>
                    <option value="bogota">Bogotá</option>
                    <option value="cali">Cali</option>
                </select>
            </div>
            <div class="search-input-group">
                <select id="propertyType" name="PropertyType" asp-for="PropertyType">
                    <option value="">Tipo de vivienda</option>
                    <option value="1">Apartamento</option>
                    <option value="2">Casa</option>
                    <option value="3">Estudio</option>
                </select>
            </div>
            <div class="search-input-group">
                <select id="priceRange" name="PriceRange" asp-for="PriceRange">
                    <option value="">Rango de precio</option>
                    <option value="low">Hasta $1.5M</option>
                    <option value="medium">$1.5M - $3M</option>
                    <option value="high">Más de $3M</option>
                </select>
            </div>
            <button type="submit" class="btn-secondary" style="height: 42px; width: 120px;">Buscar</button>
        </form>
    </div>
</section>

<!-- Features / Quick Access Section -->
<section class="features-section" id="como-funciona">
    <div class="features-grid">
        <a href="/#propiedades" class="feature-card" style="text-decoration: none; color: inherit; display: flex;">
            <div class="feature-icon">📱</div>
            <div class="feature-text">
                <h3>Acceso rápido y seguro</h3>
                <p>Explora opciones en minutos</p>
            </div>
        </a>
        <a href="/Registro" class="feature-card" style="text-decoration: none; color: inherit; display: flex;">
            <div class="feature-icon">📋</div>
            <div class="feature-text">
                <h3>Regístrate sin complicaciones</h3>
                <p>Tus datos están protegidos</p>
            </div>
        </a>
        <a href="/Comunidad" class="feature-card" style="text-decoration: none; color: inherit; display: flex;">
            <div class="feature-icon">👥</div>
            <div class="feature-text">
                <h3>Comunidad de apoyo</h3>
                <p>Comparte experiencias reales</p>
            </div>
        </a>
    </div>
</section>

<!-- Owner Section -->
<section class="owner-section">
    <h2 class="owner-section-title">¿Eres Propietario?</h2>
    
    <div class="owner-banner">
        <div class="owner-content">
            <h2 style="color: var(--primary-color);">Quiero Ofertar mi Vivienda</h2>
            <ul>
                <li>Publica gratis tu propiedad en minutos</li>
                <li>Llega a cientos de inquilinos</li>
                <li>Gestiona tus interesados sin complicaciones</li>
            </ul>
            <a href="/CrearAnuncio" class="btn-secondary" style="display: inline-block; text-decoration: none;">Publicar mi propiedad</a>
        </div>
        <div class="owner-image"></div>
    </div>
</section>

<!-- Categories / Properties Section -->
<section class="categories-section" id="propiedades">
    <h2>Propiedades Destacadas</h2>
    
    @if (Model.Properties != null && Model.Properties.Any())
    {
        <div class="categories-grid" style="grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 1.5rem;">
            @foreach (var prop in Model.Properties)
            {
                <div class="category-card" style="text-align: left; padding: 1.5rem; display: flex; flex-direction: column; justify-content: space-between;">
                    <div>
                        <h3 style="margin-top: 0; color: var(--primary-color);">@prop.Title</h3>
                        <p style="font-weight: bold; margin: 0.5rem 0;">@prop.City, @prop.Neighborhood</p>
                        <p style="margin: 0.5rem 0; font-size: 0.9rem; color: #555;">@(TranslationHelper.TranslatePropertyType(prop.Type)) - @(TranslationHelper.TranslateTransactionType(prop.Transaction))</p>
                        <h2 style="margin: 1rem 0; color: #333;">$@prop.Price.ToString("N0")</h2>
                    </div>
                    <a href="/AgendarVisita?propertyId=@prop.Id" class="btn-primary" style="text-decoration: none; text-align: center; display: block; margin-top: 1rem;">Agendar Visita</a>
                </div>
            }
        </div>
    }
    else
    {
        <div style="text-align: center; padding: 2rem;">
            <p>No se encontraron propiedades con esos filtros.</p>
        </div>
    }
</section>

<!-- Testimonials Section -->
<section class="testimonials-section" id="experiencias">
    <h2>Experiencias de Nuestros Usuarios</h2>
    
    <div class="testimonials-grid">
        <div class="testimonial-card">
            <img src="/images/ana.webp" alt="Ana G." class="testimonial-img" />
            <div class="testimonial-content">
                <h4>Ana G.</h4>
                <p class="testimonial-quote">"Ahora tengo mi hogar ideal"</p>
                <p class="testimonial-text">Encontré rápido un lugar seguro. Me sentí acompañada en todo el proceso.</p>
            </div>
        </div>
        <div class="testimonial-card">
            <img src="/images/carlos.webp" alt="Carlos M." class="testimonial-img" />
            <div class="testimonial-content">
                <h4>Carlos M.</h4>
                <p class="testimonial-quote">"Excelente servicio"</p>
                <p class="testimonial-text">Gracias a la app conseguí un departamento en pocos días. Todo fue simple y claro.</p>
            </div>
        </div>
    </div>
</section>
