@page
@model EncuentraTuHogar.Pages.EditarAnuncioModel
@{
    ViewData["Title"] = "Editar Propiedad";
}

<div class="anuncio-page">

    <!-- Header -->
    <div class="reveal" style="margin-bottom:2rem;">
        <a href="/Dashboard" style="display:inline-flex;align-items:center;gap:0.4rem;color:var(--text-muted);font-size:0.875rem;font-weight:500;margin-bottom:1rem;text-decoration:none;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
            Volver al panel
        </a>
        <span class="section-eyebrow">Edición</span>
        <h1 class="section-title" style="margin-bottom:0.5rem;">Editar anuncio de vivienda</h1>
        <p style="color:var(--text-secondary);font-size:0.9375rem;">
            Actualiza el precio o la descripción de tu propiedad.
        </p>
    </div>

    <!-- Steps indicator (visual) -->
    <div class="form-steps reveal" style="margin-bottom:2rem;">
        <div class="form-step active">
            <span class="form-step-num">1</span>
            Información básica
        </div>
        <div class="form-step">
            <span class="form-step-num">2</span>
            Ubicación
        </div>
        <div class="form-step">
            <span class="form-step-num">3</span>
            Precio y detalles
        </div>
    </div>

    <!-- Main layout: form + preview -->
    <div style="display:grid;grid-template-columns:1fr 320px;gap:2rem;align-items:start;" class="reveal">

        <!-- Form card -->
        <div class="card" style="padding:2rem;">
            <form method="post" id="anuncioForm">
                <input type="hidden" asp-for="PropertyId" />
                <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

                <!-- Row 1: Tipo de transacción + tipo de propiedad -->
                <div class="form-grid-2">
                    <div class="form-group">
                        <label asp-for="Input.Transaction" class="form-label">Tipo de transacción</label>
                        <select asp-for="Input.Transaction"
                                class="form-control"
                                asp-items="Html.GetEnumSelectList<EncuentraTuHogar.Domain.ValueObjects.TransactionType>()"
                                id="input-transaction" disabled>
                        </select>
                        <input type="hidden" asp-for="Input.Transaction" />
                    </div>
                    <div class="form-group">
                        <label asp-for="Input.Type" class="form-label">Tipo de vivienda</label>
                        <select asp-for="Input.Type"
                                class="form-control"
                                asp-items="Html.GetEnumSelectList<EncuentraTuHogar.Domain.ValueObjects.PropertyType>()"
                                id="input-type" disabled>
                        </select>
                        <input type="hidden" asp-for="Input.Type" />
                    </div>
                </div>

                <!-- Row 2: Ciudad + zona -->
                <div class="form-grid-2">
                    <div class="form-group">
                        <label asp-for="Input.City" class="form-label">Ciudad</label>
                        <input asp-for="Input.City"
                               class="form-control"
                               readonly
                               id="input-city" />
                    </div>
                    <div class="form-group">
                        <label asp-for="Input.Zone" class="form-label">Barrio / Zona</label>
                        <input asp-for="Input.Zone"
                               class="form-control"
                               readonly
                               id="input-zone" />
                    </div>
                </div>

                <!-- Street -->
                <div class="form-group">
                    <label asp-for="Input.Street" class="form-label">Dirección</label>
                    <input asp-for="Input.Street"
                           class="form-control"
                           readonly
                           id="input-street" />
                </div>

                <!-- Price -->
                <div class="form-group">
                    <label asp-for="Input.Price" class="form-label">Precio mensual (COP)</label>
                    <div style="position:relative;">
                        <span style="position:absolute;left:1rem;top:50%;transform:translateY(-50%);color:var(--text-muted);font-weight:600;font-size:0.9375rem;">$</span>
                        <input asp-for="Input.Price"
                               type="number"
                               class="form-control"
                               placeholder="1.500.000"
                               style="padding-left:2rem;"
                               id="input-price"
                               min="0" />
                    </div>
                    <span asp-validation-for="Input.Price" class="form-error"></span>
                </div>

                <!-- Description -->
                <div class="form-group" style="margin-bottom:2rem;">
                    <label asp-for="Input.Description" class="form-label">Descripción de la vivienda</label>
                    <textarea asp-for="Input.Description"
                              rows="4"
                              class="form-control"
                              placeholder="Describe las características principales: habitaciones, baños, garaje, servicios incluidos, normas de convivencia..."
                              id="input-description"></textarea>
                    <span asp-validation-for="Input.Description" class="form-error"></span>
                </div>

                <button type="submit" class="btn btn-primary btn-lg btn-full" id="btn-publicar-anuncio">
                    Guardar cambios
                </button>
            </form>
        </div>

        <!-- Preview card -->
        <div style="position:sticky;top:88px;">
            <div class="card" style="border-color:var(--primary-light);">
                <div style="background:linear-gradient(135deg,var(--bg-muted),var(--primary-light));height:140px;border-radius:var(--radius-sm);margin-bottom:1rem;display:flex;align-items:center;justify-content:center;font-size:3rem;opacity:0.5;">🏠</div>
                <span class="badge badge-green" style="margin-bottom:0.625rem;" id="preview-type">Tu vivienda</span>
                <div style="font-size:0.875rem;color:var(--text-secondary);margin-bottom:0.25rem;" id="preview-location">
                    📍 Ciudad, Barrio
                </div>
                <div style="font-size:1.375rem;font-weight:800;color:var(--primary);letter-spacing:-0.03em;margin:0.5rem 0;" id="preview-price">
                    $— /mes
                </div>
                <div style="font-size:0.8rem;color:var(--text-muted);line-height:1.5;" id="preview-desc">
                    La descripción aparecerá aquí...
                </div>
                <div style="margin-top:1rem;padding-top:1rem;border-top:1px solid var(--border);display:flex;align-items:center;gap:0.5rem;">
                    <span class="badge badge-gray">Vista previa</span>
                    <span style="font-size:0.75rem;color:var(--text-muted);">Así verán tu anuncio</span>
                </div>
            </div>

            <!-- Tips -->
            <div style="margin-top:1rem;background:var(--accent-light);border:1px solid rgba(37,99,235,0.15);border-radius:var(--radius);padding:1rem;">
                <p style="font-size:0.8125rem;font-weight:700;color:var(--accent);margin-bottom:0.5rem;">💡 Consejos</p>
                <ul style="font-size:0.8rem;color:var(--text-secondary);padding-left:1rem;line-height:1.7;margin:0;">
                    <li>Una descripción detallada atrae más inquilinos</li>
                    <li>El precio justo reduce el tiempo de espera</li>
                    <li>Prioriza perfiles verificados de la comunidad</li>
                </ul>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Live preview
        function updatePreview() {
            const city = document.getElementById('input-city')?.value || '';
            const zone = document.getElementById('input-zone')?.value || '';
            const price = document.getElementById('input-price')?.value || '';
            const desc = document.getElementById('input-description')?.value || '';
            const typeEl = document.getElementById('input-type');
            const typeText = typeEl?.options[typeEl?.selectedIndex]?.text || 'Tu vivienda';

            const loc = [city, zone].filter(Boolean).join(', ') || 'Ciudad, Barrio';
            document.getElementById('preview-location').textContent = '📍 ' + loc;
            document.getElementById('preview-price').textContent = price
                ? '$' + parseInt(price).toLocaleString('es-CO') + ' /mes'
                : '$— /mes';
            document.getElementById('preview-desc').textContent = desc.substring(0, 100) + (desc.length > 100 ? '...' : '');
            document.getElementById('preview-type').textContent = typeText !== 'Seleccione...' ? typeText : 'Tu vivienda';
        }

        ['input-city','input-zone','input-price','input-description','input-type'].forEach(id => {
            document.getElementById(id)?.addEventListener('input', updatePreview);
            document.getElementById(id)?.addEventListener('change', updatePreview);
        });
    </script>
}
